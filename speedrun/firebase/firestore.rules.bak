rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Speedrun MCAT questions — any authenticated user (including anonymous)
    match /speedrun_questions/{docId} {
      allow read, write: if request.auth != null;
    }
    // Performance records are scoped per sync identity (SPEEDRUN_SYNC_ID).
    match /speedrun_performance/{syncId}/records/{recordId} {
      allow read, write: if request.auth != null;
    }
    // All other collections require authentication
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
